# Backend Environment Variables
# Copy this file to .env and fill in the values

# Groq LLM API Key — get from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# PostgreSQL connection string
# Local dev example:  postgresql://user:password@localhost/medical_ai
# Neon example:       postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/medical_ai?sslmode=require
DATABASE_URL=postgresql://user:password@localhost/medical_ai

# Allowed frontend origin for CORS (set to your Vercel URL in production)
# Example: https://your-app.vercel.app
ALLOWED_ORIGIN=http://localhost:3000
