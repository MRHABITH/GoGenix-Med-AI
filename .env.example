# Root-level Environment Variables
# Copy this file to .env and fill in the values

# ---- Backend ----
GROQ_API_KEY=your_groq_api_key_here

# For local dev with the DB container below:
DATABASE_URL=postgresql://user:password@db:5432/medical_ai

# For Neon (production):
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/medical_ai?sslmode=require

# Comma-separated allowed frontend origins for CORS
# Local dev:
ALLOWED_ORIGIN=http://localhost:3000
# Production (your Vercel URL):
# ALLOWED_ORIGIN=https://your-app.vercel.app

# ---- Frontend ----
# Local dev:
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production (your Render backend URL):
# NEXT_PUBLIC_API_URL=https://your-backend.onrender.com

# ---- Postgres (local dev docker-compose only) ----
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=medical_ai
